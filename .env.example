# ──────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&sslmode=require"

# ──────────────────────────────────────────────────────────
# Magic-link auth (required for production / Railway)
# ──────────────────────────────────────────────────────────
# 64-char random hex; signs both magic link tokens and session cookies.
# Generate: openssl rand -hex 32
APP_AUTH_SECRET="your-64-char-hex-secret-here"

# Optional: a separate secret just for magic-link tokens (falls back to APP_AUTH_SECRET).
# APP_AUTH_LINK_SECRET="another-secret"

# Allow-list — single-user app locks to ONE email via APP_AUTH_EMAIL.
# If unset, falls back to ALLOWED_EMAILS (comma-separated). If both unset, anyone can sign in.
APP_AUTH_EMAIL="you@example.com"
# ALLOWED_EMAILS="a@example.com,b@example.com"

# Resend transactional email (required when APP_AUTH_SECRET is set).
# Sign up at https://resend.com, create an API key.
RESEND_API_KEY="re_xxxxxxxxxxxx"
APP_AUTH_FROM_EMAIL="Meal Planner <no-reply@resend.dev>"

# Base URL used to build magic-link verification URLs. Railway injects this after first deploy;
# set to your custom domain or https://<service>.up.railway.app.
APP_BASE_URL="http://localhost:3000"

# Single-tenant mode — every authenticated request resolves to one household.
# Keep this as "true" for Path A single-user deployment.
APP_SINGLE_USER="true"

# ──────────────────────────────────────────────────────────
# Encryption (required — used for Paprika credentials at rest)
# ──────────────────────────────────────────────────────────
# 64-char hex (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here"

# ──────────────────────────────────────────────────────────
# AI providers
# ──────────────────────────────────────────────────────────
# Primary provider
OPENAI_API_KEY="your-openai-api-key"
# Fallback/alternative provider (optional)
ANTHROPIC_API_KEY="your-anthropic-api-key"
# "openai" (default) or "anthropic"
AI_PROVIDER="openai"

# ──────────────────────────────────────────────────────────
# Paprika recipe sync (optional — configured per-household in Settings UI)
# ──────────────────────────────────────────────────────────
# PAPRIKA_EMAIL="your-paprika-email"
# PAPRIKA_PASSWORD="your-paprika-password"

# ──────────────────────────────────────────────────────────
# Legacy / unused (kept for future multi-user auth — do not set in production today)
# ──────────────────────────────────────────────────────────
# NEXTAUTH_SECRET="your-nextauth-secret-here"
# NEXTAUTH_URL="http://localhost:3000"
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
