# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI (Primary AI Provider)
OPENAI_API_KEY="your-openai-api-key"

# Anthropic (Secondary/Fallback AI Provider)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AI Provider Selection (openai or anthropic)
AI_PROVIDER="openai"

# Encryption Key for Sensitive Data (32 bytes as 64-char hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here"

# Paprika Credentials (for recipe sync)
PAPRIKA_EMAIL="your-paprika-email"
PAPRIKA_PASSWORD="your-paprika-password"

# Google Calendar (Phase 1.1)
# Uses same GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET as OAuth
