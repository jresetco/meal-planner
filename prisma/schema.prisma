// Prisma schema for Meal Planner
// Supports: Users, Households, Recipes, Meal Plans, Grocery Lists

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Core Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  household   Household? @relation(fields: [householdId], references: [id])
  householdId String?
}

model Household {
  id        String   @id @default(cuid())
  name      String   @default("My Household")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]
  recipes         Recipe[]
  mealPlans       MealPlan[]
  softRules       SoftRule[]
  pantryStaples   PantryStaple[]
  historicalPlans HistoricalPlan[]
  mealSettings    MealSettings?
  baselinePresets BaselinePreset[]
  mealEditHistory MealEditHistory[]
}

model MealSettings {
  id          String  @id @default(cuid())
  householdId String  @unique
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Default meal times
  breakfastTime String @default("08:00")
  lunchTime     String @default("12:00")
  dinnerTime    String @default("18:00")

  // Default enabled meals
  breakfastEnabled Boolean @default(true)
  lunchEnabled     Boolean @default(true)
  dinnerEnabled    Boolean @default(true)

  // Default servings per meal
  defaultServings Int @default(2)

  // Max repeats default
  defaultMaxRepeats Int @default(2)

  // Max leftover meals per week
  maxLeftoversPerWeek Int @default(3)

  // Paprika integration
  paprikaEmail    String?
  paprikaPassword String? // Encrypted
  paprikaCategories String[] @default([]) // Category filter for sync (empty = all)
  paprikaMinRating Int?     // Min star rating to sync (0 or null = include all)
  paprikaLastSync DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BaselinePreset {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  name              String
  isDefault         Boolean @default(false)
  maxLeftovers      Int     @default(3)
  servingsPerMeal   Int     @default(4)
  guaranteedMealIds String[] // Recipe IDs that must be included
  guidelines        String?  @db.Text // Open-text planning guidelines for AI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
}

// ============================================
// Recipes
// ============================================

model Recipe {
  id          String   @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Source tracking
  source      RecipeSource @default(CUSTOM)
  paprikaId   String?      @unique
  sourceUrl   String?

  // Recipe details
  name         String
  description  String?
  ingredients  Json      // Array of { name, quantity, unit }
  instructions String?   @db.Text
  servings     Int       @default(2)
  rating       Int?      // 1-5 stars
  prepTime     Int?      // minutes
  cookTime     Int?      // minutes
  totalTime    Int?      // minutes
  imageUrl     String?
  icon         String?   // Food icon name (e.g., "pizza", "salad")
  categories   String[]  // Tags/categories
  notes        String?   @db.Text

  // Recipe classification for AI planning
  recipeType   RecipeType @default(REGULAR) // Staple, Special, Regular
  maxFrequency MaxFrequency @default(WEEKLY) // How often this can appear
  
  // Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  plannedMeals PlannedMeal[]

  @@index([householdId])
  @@index([source])
  @@index([rating])
  @@index([recipeType])
}

enum RecipeType {
  STAPLE    // Go-to recipes, can use frequently
  REGULAR   // Normal rotation recipes
  SPECIAL   // Rare/high-effort/treat recipes
}

enum MaxFrequency {
  DAILY     // Can appear every day
  WEEKLY    // Can appear every week
  BIWEEKLY  // Every 2 weeks
  MONTHLY   // Once a month max
}

enum RecipeSource {
  PAPRIKA
  CUSTOM
  AI_DISCOVERED
  WEB_IMPORT
}

// ============================================
// Meal Planning
// ============================================

model MealPlan {
  id          String   @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Plan details
  name      String?
  startDate DateTime
  endDate   DateTime
  status    PlanStatus @default(DRAFT)

  // Generation parameters (stored for reference)
  generationParams Json? // { maxRepeats, enabledMeals, softRules used, etc. }

  // AI reasoning (optional, for debugging/display)
  aiReasoning String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  plannedMeals PlannedMeal[]
  groceryList  GroceryList?

  @@index([householdId])
  @@index([status])
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model PlannedMeal {
  id         String   @id @default(cuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  // Meal slot
  date     DateTime
  mealType MealType

  // What's being served
  recipeId  String?
  recipe    Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  customName String? // For non-recipe meals (e.g., "Eating Out")

  // Leftover tracking
  isLeftover       Boolean @default(false)
  leftoverSourceId String? // Points to original PlannedMeal
  leftoverSource   PlannedMeal?  @relation("LeftoverSource", fields: [leftoverSourceId], references: [id], onDelete: SetNull)
  leftovers        PlannedMeal[] @relation("LeftoverSource")

  // Status
  status   MealStatus @default(PLANNED)
  servings Int        @default(2)
  isLocked Boolean    @default(false) // Prevent regeneration

  // Google Calendar integration
  calendarEventId String?

  // Notes
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mealPlanId, date, mealType])
  @@index([mealPlanId])
  @@index([date])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum MealStatus {
  PLANNED
  EATING_OUT
  SKIPPED
  COMPLETED
}

// ============================================
// Grocery List
// ============================================

model GroceryList {
  id         String   @id @default(cuid())
  mealPlanId String   @unique
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items GroceryItem[]
}

model GroceryItem {
  id            String      @id @default(cuid())
  groceryListId String
  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)

  // Item details
  name       String
  quantity   Float?
  unit       String?
  section    StoreSection @default(OTHER)
  mealNames  String[]     // Which meals need this ingredient

  // Status
  isChecked Boolean @default(false)
  isStaple  Boolean @default(false) // Excluded from shopping

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groceryListId])
  @@index([section])
}

enum StoreSection {
  PRODUCE
  DAIRY
  MEAT_SEAFOOD
  BAKERY
  FROZEN
  PANTRY
  CANNED_GOODS
  CONDIMENTS
  BEVERAGES
  SPICES
  INTERNATIONAL
  OTHER
}

// ============================================
// Settings & Preferences
// ============================================

model SoftRule {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  ruleText   String
  isActive   Boolean  @default(true)
  isHardRule Boolean  @default(false) // true = must-do constraint, false = soft preference
  priority   Int      @default(0) // Higher = more important

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
}

model PantryStaple {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  ingredientName String
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, ingredientName])
  @@index([householdId])
}

// ============================================
// Historical Data (for AI training)
// ============================================

model HistoricalPlan {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  importedAt  DateTime @default(now())
  source      String?  // "csv", "json", "manual", "table"
  rawData     String?  @db.Text // Original raw input
  data        Json     // Parsed structure: { meals: [{ date, mealType, recipeName, isLeftover }] }
  weekCount   Int      @default(1) // Number of weeks in this historical data
  description String?  // User-provided description of this period

  @@index([householdId])
}

// ============================================
// Edit Tracking (for AI learning)
// ============================================

model MealEditHistory {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  
  mealPlanId  String
  
  // What was changed
  editType    EditType
  date        DateTime
  mealType    MealType
  
  // Before/After
  originalRecipeId   String?
  originalRecipeName String?
  newRecipeId        String?
  newRecipeName      String?
  
  // Context for learning
  reason      String?  // User-provided reason for change (optional)
  aiGenerated Boolean  @default(true) // Was the original AI-generated?
  
  createdAt   DateTime @default(now())
  
  @@index([householdId])
  @@index([mealPlanId])
  @@index([editType])
}

enum EditType {
  SWAP       // Replaced with different recipe
  REGENERATE // AI regenerated this slot
  DELETE     // Removed meal
  LOCK       // Locked meal (signals satisfaction)
  UNLOCK     // Unlocked meal
}
